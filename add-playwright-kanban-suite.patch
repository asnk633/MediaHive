+import type { Page } from '@playwright/test';
+
+/**
+ * Helpers for seeding and fetching tasks using the real backend.
+ *
+ * seedTask(page, user, overrides) -> creates a task via POST /api/tasks
+ * fetchTaskById(page, id) -> tries GET /api/tasks/:id then falls back to list search.
+ */
+
+export async function seedTask(page: Page, user: any, overrides: Partial<any> = {}) {
+  const baseUrl = process.env.PLAYWRIGHT_BASE_URL || 'http://localhost:3000';
+  const payload = {
+    institutionId: 1,
+    title: `e2e task ${Date.now()}`,
+    description: 'seeded via e2e auth',
+    status: 'todo',
+    priority: 'medium',
+    ...overrides,
+  };
+
+  const resp = await page.request.post(`${baseUrl}/api/tasks`, {
+    headers: {
+      'content-type': 'application/json',
+      'x-user-data': JSON.stringify(user),
+    },
+    data: payload,
+  });
+
+  if (!(resp.ok())) {
+    const text = await resp.text();
+    throw new Error(`seedTask failed: ${resp.status()} ${text}`);
+  }
+
+  // Expect { data: ... } or the object directly
+  const json = await resp.json();
+  return json?.data ?? json;
+}
+
+export async function fetchTaskById(page: Page, id: number | string) {
+  const baseUrl = process.env.PLAYWRIGHT_BASE_URL || 'http://localhost:3000';
+
+  // Try direct read if route exists
+  try {
+    const resp = await page.request.get(`${baseUrl}/api/tasks/${id}`);
+    if (resp.ok()) {
+      const json = await resp.json();
+      return json?.data ?? json;
+    }
+  } catch (err) {
+    // ignore and fallback
+  }
+
+  // Fallback: fetch all tasks and search
+  const listResp = await page.request.get(`${baseUrl}/api/tasks?institutionId=1&limit=500`);
+  if (!listResp.ok()) {
+    throw new Error(`fetchTaskById fallback failed: ${listResp.status()} ${await listResp.text()}`);
+  }
+  const listJson = await listResp.json();
+  const items = listJson?.data ?? listJson;
+  return Array.isArray(items) ? items.find((t: any) => String(t.id) === String(id)) : null;
+}
+
+export async function deleteTaskById(page: Page, id: number | string) {
+  const baseUrl = process.env.PLAYWRIGHT_BASE_URL || 'http://localhost:3000';
+  try {
+    const resp = await page.request.delete(`${baseUrl}/api/tasks/${id}`, {
+      headers: { 'x-user-data': page.context()._options.storageState ? '' : '' }, // placeholder; often not needed
+    });
+    return resp.ok();
+  } catch {
+    return false;
+  }
+}

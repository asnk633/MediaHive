+  todoColumn: '[data-testid="todo-column"]',
+  inProgressColumn: '[data-testid="in-progress-column"]',
+  doneColumn: '[data-testid="done-column"]',
+  taskRow: ".task-row",
+  taskRowById: (id: number) => `[data-task-id="${id}"]`,

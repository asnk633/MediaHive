+import type { Page, Locator } from '@playwright/test';
+
+/**
+ * Robust drag helper using mouse moves & bounding boxes.
+ *
+ * Usage:
+ *   await dragAndDrop(page, locatorSource, locatorTarget);
+ *
+ * The helper:
+ * - waits for bounding boxes to be available
+ * - moves to the source center, mouse.down(), moves in steps to the target center, mouse.up()
+ * - short waits to allow UI to process the drop
+ */
+
+export async function dragAndDrop(page: Page, source: Locator, target: Locator, opts?: { steps?: number; pauseMs?: number; postDropMs?: number; }) {
+  const steps = opts?.steps ?? 12;
+  const pauseMs = opts?.pauseMs ?? 40;
+  const postDropMs = opts?.postDropMs ?? 450;
+
+  const srcBox = await source.boundingBox();
+  const tgtBox = await target.boundingBox();
+  if (!srcBox || !tgtBox) {
+    throw new Error('dragAndDrop: could not retrieve bounding boxes for source or target');
+  }
+
+  const src = { x: srcBox.x + srcBox.width / 2, y: srcBox.y + srcBox.height / 2 };
+  const tgt = { x: tgtBox.x + tgtBox.width / 2, y: tgtBox.y + tgtBox.height / 2 };
+
+  // Move to source center
+  await page.mouse.move(src.x, src.y);
+  await page.mouse.down();
+  await page.waitForTimeout(pauseMs);
+
+  // Move in small steps to target
+  for (let i = 1; i <= steps; i++) {
+    const t = i / steps;
+    const x = src.x + (tgt.x - src.x) * t;
+    const y = src.y + (tgt.y - src.y) * t;
+    await page.mouse.move(x, y, { steps: 2 });
+    await page.waitForTimeout(10);
+  }
+
+  await page.mouse.up();
+  // Give the UI & backend a moment to reconcile
+  await page.waitForTimeout(postDropMs);
+}
+
+export default dragAndDrop;

+import test, { expect } from './fixtures';
+import { seedTask, fetchTaskById } from './helpers/seed';
+import dragAndDrop from './helpers/drag';
+import type { Locator } from '@playwright/test';
+
+/**
+ * Full Kanban suite
+ *
+ * - Uses real backend seeding
+ * - Uses client-side auth via localStorage (authUser fixture)
+ * - Verifies UI and backend after drag
+ *
+ * Selectors are centralized for easy tuning.
+ */
+
+const SELECTORS = {
+  taskRow: '.task-row',
+  column: (name: string) => `[data-column="${name}"]`,
+  taskById: (id: any) => `[data-task-id="${id}"]`,
+  taskTitle: 'h3, .task-title',
+};
+
+const TIMEOUTS = {
+  pageLoad: 20000,
+  taskVisible: 10000,
+};
+
+async function waitForTasksInColumn(page: any, columnName: string) {
+  const sel = SELECTORS.column(columnName);
+  await page.waitForSelector(sel, { timeout: TIMEOUTS.pageLoad });
+  // wait for at least one task-row inside that column (if present)
+  await page.waitForSelector(`${sel} ${SELECTORS.taskRow}`, { timeout: TIMEOUTS.taskVisible }).catch(() => { /* allow empty column */ });
+}
+
+test.describe('kanban full suite', () => {
+  test('can seed tasks and verify they show up', async ({ page, authUser }) => {
+    // seed a task
+    const created = await seedTask(page, authUser, { title: 'e2e-seed-basic', status: 'todo' });
+
+    // navigate to tasks page (client auth set by fixture via addInitScript)
+    await page.goto('/tasks');
+    // ensure things hydrate
+    await waitForTasksInColumn(page, 'todo');
+
+    // assert the created task is visible
+    const locator = page.locator(SELECTORS.taskById(created.id));
+    await expect(locator).toBeVisible({ timeout: TIMEOUTS.taskVisible });
+    // assert title is shown
+    await expect(locator.locator(SELECTORS.taskTitle)).toHaveText(/e2e-seed-basic/);
+  });
+
+  test('drag todo -> in_progress updates UI and backend', async ({ page, authUser }) => {
+    // seed task in todo
+    const task = await seedTask(page, authUser, { title: 'drag-todo-to-inprogress', status: 'todo' });
+
+    await page.goto('/tasks');
+    await waitForTasksInColumn(page, 'todo');
+    await waitForTasksInColumn(page, 'in_progress');
+
+    // locate source and target elements
+    const source = page.locator(SELECTORS.taskById(task.id));
+    await expect(source).toBeVisible({ timeout: TIMEOUTS.taskVisible });
+
+    const targetCol = page.locator(SELECTORS.column('in_progress'));
+    await expect(targetCol).toBeVisible({ timeout: TIMEOUTS.pageLoad });
+
+    // Perform drag
+    await dragAndDrop(page, source, targetCol);
+
+    // Wait for the task to appear in the target column
+    const movedTask = page.locator(`${SELECTORS.column('in_progress')} ${SELECTORS.taskById(task.id)}`);
+    await expect(movedTask).toBeVisible({ timeout: TIMEOUTS.taskVisible });
+
+    // Check backend: ensure task status updated
+    const fresh = await fetchTaskById(page, task.id);
+    if (!fresh) throw new Error('fetchTaskById returned null after drag');
+    expect(fresh.status).toBe('in_progress');
+  });
+
+  test('drag todo -> done updates UI and backend', async ({ page, authUser }) => {
+    const task = await seedTask(page, authUser, { title: 'drag-todo-to-done', status: 'todo' });
+
+    await page.goto('/tasks');
+    await waitForTasksInColumn(page, 'todo');
+    await waitForTasksInColumn(page, 'done');
+
+    const source = page.locator(SELECTORS.taskById(task.id));
+    await expect(source).toBeVisible({ timeout: TIMEOUTS.taskVisible });
+
+    const targetCol = page.locator(SELECTORS.column('done'));
+    await expect(targetCol).toBeVisible({ timeout: TIMEOUTS.pageLoad });
+
+    await dragAndDrop(page, source, targetCol);
+
+    const movedTask = page.locator(`${SELECTORS.column('done')} ${SELECTORS.taskById(task.id)}`);
+    await expect(movedTask).toBeVisible({ timeout: TIMEOUTS.taskVisible });
+
+    const fresh = await fetchTaskById(page, task.id);
+    if (!fresh) throw new Error('fetchTaskById returned null after drag');
+    expect(fresh.status).toBe('done');
+  });
+
+  test('column counts reflect seeded data', async ({ page, authUser }) => {
+    // seed multiple tasks in different statuses
+    const t1 = await seedTask(page, authUser, { title: 'count-task-todo', status: 'todo' });
+    const t2 = await seedTask(page, authUser, { title: 'count-task-inprogress', status: 'in_progress' });
+    const t3 = await seedTask(page, authUser, { title: 'count-task-done', status: 'done' });
+
+    await page.goto('/tasks');
+    await waitForTasksInColumn(page, 'todo');
+    await waitForTasksInColumn(page, 'in_progress');
+    await waitForTasksInColumn(page, 'done');
+
+    // count items
+    const todoCount = await page.locator(`${SELECTORS.column('todo')} ${SELECTORS.taskRow}`).count();
+    const inProgCount = await page.locator(`${SELECTORS.column('in_progress')} ${SELECTORS.taskRow}`).count();
+    const doneCount = await page.locator(`${SELECTORS.column('done')} ${SELECTORS.taskRow}`).count();
+
+    // at minimum, each column should have at least 1 because of our seeds
+    expect(todoCount).toBeGreaterThanOrEqual(1);
+    expect(inProgCount).toBeGreaterThanOrEqual(1);
+    expect(doneCount).toBeGreaterThanOrEqual(1);
+  });
+});
+
+// NOTE:
+// If your app uses different selectors, update SELECTORS above.
+// If tests fail due to timing, increase TIMEOUTS.pageLoad or TIMEOUTS.taskVisible.

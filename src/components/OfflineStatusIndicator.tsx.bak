"use client";
import React from 'react';
import { useOffline } from '@/hooks/useOffline';
import { ConflictResolutionModal } from './ConflictResolutionModal';

export function OfflineStatusIndicator() {
  const { 
    isOnline, 
    pendingSyncCount, 
    conflicts, 
    isProcessing, 
    processSyncQueue 
  } = useOffline();
  
  const [showConflictModal, setShowConflictModal] = React.useState(false);
  const [currentConflict, setCurrentConflict] = React.useState<any>(null);

  // Show conflict modal when conflicts are detected
  React.useEffect(() => {
    if (conflicts.length > 0 && !showConflictModal) {
      setCurrentConflict(conflicts[0]);
      setShowConflictModal(true);
    }
  }, [conflicts, showConflictModal]);

  const handleResolveConflict = () => {
    setShowConflictModal(false);
    setCurrentConflict(null);
  };

  if (isOnline && pendingSyncCount === 0 && conflicts.length === 0) {
    return null;
  }

  return (
    <>
      <div className="fixed bottom-20 left-4 right-4 z-40">
        <div className={`p-3 rounded-lg shadow-lg ${
          isOnline ? 'bg-green-900' : 'bg-red-900'
        }`}>
          <div className="flex items-center justify-between">
            <div className="flex items-center space-x-2">
              <div className={`w-3 h-3 rounded-full ${
                isOnline ? 'bg-green-500' : 'bg-red-500'
              }`}></div>
              <span className="font-medium">
                {isOnline ? 'Online' : 'Offline'}
              </span>
            </div>
            
            {pendingSyncCount > 0 && (
              <div className="flex items-center space-x-2">
                <span className="text-sm">
                  {pendingSyncCount} pending sync
                </span>
                <button
                  onClick={processSyncQueue}
                  disabled={isProcessing}
                  className="px-2 py-1 bg-white bg-opacity-20 hover:bg-opacity-30 rounded text-sm disabled:opacity-50"
                >
                  {isProcessing ? 'Syncing...' : 'Sync Now'}
                </button>
              </div>
            )}
          </div>
          
          {!isOnline && (
            <div className="mt-2 text-sm">
              Changes will be synced when you're back online
            </div>
          )}
        </div>
      </div>
      
      {showConflictModal && currentConflict && (
        <ConflictResolutionModal
          conflict={currentConflict}
          onClose={() => setShowConflictModal(false)}
          onResolve={handleResolveConflict}
        />
      )}
    </>
  );
}

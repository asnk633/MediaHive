+    const me = (await meResp.json()).find((u: any) => u.email === (process.env.PLAYWRIGHT_TEST_EMAIL || 'dev@local')) || (await meResp.json())[0];
+    const task = await seedTask(page, me);
+    await page.goto('/tasks');
+    await page.waitForSelector(`[data-task-id="${task.id}"]`, { timeout: 15000 });
+    const el = page.locator(`[data-task-id="${task.id}"]`);
+    await expect(el).toBeVisible();
+    await expect(el.locator('h3')).toHaveText(task.title);
+    await expect(el).toContainText(task.description);
+  });
+
+  test('verifies task attributes are correctly displayed', async ({ page }) => {
+    const meResp = await page.request.get(`${BASE}/api/users`);
+    const me = (await meResp.json()).find((u: any) => u.email === (process.env.PLAYWRIGHT_TEST_EMAIL || 'dev@local')) || (await meResp.json())[0];

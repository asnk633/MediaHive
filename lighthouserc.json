{
  "ci": {
    "collect": {
      "staticDistDir": ".next",
      "url": [
        "http://localhost/tasks",
        "http://localhost/kanban"
      ]
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:pwa": ["error", {"minScore": 0.9}],
        "installable-manifest": "error",
        "service-worker": "error",
        "offline-start-url": "error",
        "viewport": "error",
        "content-width": "error",
        "without-javascript": "error"
      }
    }
  }
}
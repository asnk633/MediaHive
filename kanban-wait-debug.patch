+import { test, expect } from "@playwright/test";
+
+// Helper: navigate to /tasks, wait for networkidle and for kanban selector.
+// If the selector doesn't appear within the timeout, dump page HTML (first 20k chars)
+// to the test output to help debug missing DOM.
+async function gotoTasksAndWaitForKanban(page, timeout = 10000) {
+  await page.goto("/tasks", { waitUntil: "domcontentloaded" });
+  await page.waitForLoadState("networkidle", { timeout: timeout }).catch(() => {
+    // continue — we'll try selector wait next
+  });
+
+  try {
+    await page.waitForSelector('[data-column="todo"]', { timeout });
+    return;
+  } catch (err) {
+    try {
+      const html = await page.content();
+      // Print snapshot (trim to avoid huge logs)
+      console.log("=== Playwright HTML snapshot (first 20000 chars) ===\n", html.slice(0, 20000));
+    } catch (e) {
+      console.log("Could not read page content:", e);
+    }
+    // rethrow the original selector error so Playwright marks the test failed + captures artifacts
+    throw err;
+  }
+}
+
+test.describe("kanban", () => {
+  test("guest sees To Do column and cannot drag tasks to in_progress", async ({ page }) => {
+    await gotoTasksAndWaitForKanban(page, 15000);
+

# Custom iOS Podfile for MediaHive
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # 1. Force settings on all Pods targets
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
      config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'NO'
    end
  end

  # 2. Force settings at the Pods project level
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
    config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'NO'
  end

  # 3. Force settings at the main Runner project level and target level
  main_project_path = File.join(File.dirname(__FILE__), 'Runner.xcodeproj')
  main_project = Xcodeproj::Project.open(main_project_path)
  
  main_project.build_configurations.each do |config|
    config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
    config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'NO'
  end

  main_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
      config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'NO'
    end
  end
  
  main_project.save

  # 4. Modify all generated CocoaPods xcconfig files to ensure BUILD_LIBRARY_FOR_DISTRIBUTION is NO
  Dir.glob(File.join(File.dirname(__FILE__), 'Pods/Target Support Files/**/*.xcconfig')).each do |xcconfig_path|
    content = File.read(xcconfig_path)
    
    if content.include?('BUILD_LIBRARY_FOR_DISTRIBUTION')
      content.gsub!(/BUILD_LIBRARY_FOR_DISTRIBUTION\s*=\s*YES/, 'BUILD_LIBRARY_FOR_DISTRIBUTION = NO')
    else
      content << "\nBUILD_LIBRARY_FOR_DISTRIBUTION = NO\n"
    end
    
    if content.include?('APPLICATION_EXTENSION_API_ONLY')
      content.gsub!(/APPLICATION_EXTENSION_API_ONLY\s*=\s*YES/, 'APPLICATION_EXTENSION_API_ONLY = NO')
    else
      content << "\nAPPLICATION_EXTENSION_API_ONLY = NO\n"
    end
    
    File.write(xcconfig_path, content)
  end

  # 5. Modify all Flutter xcconfig files to ensure BUILD_LIBRARY_FOR_DISTRIBUTION is NO
  Dir.glob(File.join(File.dirname(__FILE__), 'Flutter/*.xcconfig')).each do |xcconfig_path|
    content = File.read(xcconfig_path)
    
    if content.include?('BUILD_LIBRARY_FOR_DISTRIBUTION')
      content.gsub!(/BUILD_LIBRARY_FOR_DISTRIBUTION\s*=\s*YES/, 'BUILD_LIBRARY_FOR_DISTRIBUTION = NO')
    else
      content << "\nBUILD_LIBRARY_FOR_DISTRIBUTION = NO\n"
    end
    
    if content.include?('APPLICATION_EXTENSION_API_ONLY')
      content.gsub!(/APPLICATION_EXTENSION_API_ONLY\s*=\s*YES/, 'APPLICATION_EXTENSION_API_ONLY = NO')
    else
      content << "\nAPPLICATION_EXTENSION_API_ONLY = NO\n"
    end
    
    File.write(xcconfig_path, content)
  end
end

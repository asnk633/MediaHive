+
+jobs:
+  playwright:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - name: Setup Node
+        uses: actions/setup-node@v4
+        with:
+          node-version: 20
+      - name: Install deps
+        run: npm ci
+      - name: Build Next app
+        run: npm run build
+      - name: Start app (background)
+        run: |
+          npm run start & sleep 3
+        env:
+          PORT: 3000
+      - name: Wait for app
+        run: |
+          npx wait-on http://localhost:3000 || npx wait-on http://127.0.0.1:3000
+      - name: Seed DB (placeholder)
+        run: |
+          echo "::notice::If your CI needs DB seeding, replace this placeholder step with your seeding commands."
+      - name: Run Playwright tests
+        run: npx playwright test --config=playwright.config.cjs --project=chromium
+        env:
+          PLAYWRIGHT_BASE_URL: http://localhost:3000
+          PLAYWRIGHT_TEST_EMAIL: dev@local

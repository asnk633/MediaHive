+// --- e2e helpers: seed tasks + robust navigation -------------------------
+// Uses PLAYWRIGHT_BASE_URL env var (set to http://localhost:3000 in your shell).
+// Optional: set PLAYWRIGHT_API_TOKEN to include Bearer auth for seeding.
+const API_BASE = process.env.PLAYWRIGHT_BASE_URL || "";
+const API_TOKEN = process.env.PLAYWRIGHT_API_TOKEN || "";
+
+test.beforeEach(async ({ request }) => {
+  // Build headers only if token provided
+  const headers = API_TOKEN ? { Authorization: `Bearer ${API_TOKEN}` } : {};
+
+  try {
+    const resp = await request.post(`${API_BASE}/api/tasks`, {
+      data: {
+        title: "e2e seeded task",
+        description: "seeded by e2e beforeEach",
+        institutionId: 1,
+        status: "todo",
+        priority: "low"
+      },
+      headers,
+    });
+
+    if (!resp.ok()) {
+      // Print short body for debugging (do not crash the test run)
+      let text = "";
+      try { text = await resp.text(); } catch (e) { text = "(cannot read body)"; }
+      console.warn(`[e2e] task seeding failed: ${resp.status()} ${text}`);
+    } else {
+      const body = await resp.json().catch(() => null);
+      console.log("[e2e] seeded task id:", body?.id ?? "(no id)");
+    }
+  } catch (err) {
+    console.warn("[e2e] error seeding task:", err);
+  }
+});

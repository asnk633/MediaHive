{
  "name": "thaiba-garden-media-manager",
  "version": "2.5.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "node ./scripts/dev.js",
    "build": "next build",
    "build:web-for-capacitor": "node ./scripts/check-envs.js && node ./scripts/validate-firebase-config.js && next build",
    "build:mobile": "cross-env IS_MOBILE=true node ./scripts/validate-mobile-api-url.js && node ./scripts/setup-mobile-env.js && node ./scripts/toggle-middleware.js disable && next build && node ./scripts/toggle-middleware.js enable && node ./scripts/harden-android.js && npx cap copy android && node ./scripts/post-copy-harden.js && node ./scripts/validate-assets.js",
    "cap:sync": "npx cap sync android",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "BASE_URL=http://localhost:3000 playwright test",
    "test:e2e:win": "set BASE_URL=http://localhost:3000&& playwright test",
    "test:e2e:wait-db": "node ./scripts/wait-for-db.js",
    "test:e2e:run": "node ./scripts/run-e2e-tests.js",
    "test:e2e:run:win": "node ./scripts/run-e2e-tests.js",
    "test:unit": "npx jest --passWithNoTests",
    "test:ui": "npx playwright test --retries=0",
    "test:full-ui": "node ./scripts/run-full-ui-tests.js",
    "ci:ensure-lock": "bash ci/ensure-pnpm-lock.sh",
    "ci:validate-mobile-api": "cross-env IS_MOBILE=true node ./scripts/validate-mobile-api-url.js",
    "test": "npm run test:unit && npm run test:ui",
    "seed": "ts-node -r tsconfig-paths/register --transpile-only src/db/seed.ts",
    "audit:full": "node ./scripts/audit/full-audit.js",
    "audit:ci": "node ./scripts/audit/full-audit.js --ci",
    "audit:generate-summary": "node ./scripts/audit/generate-summary.js",
    "audit:run-lighthouse": "bash scripts/audit/run-lighthouse.sh",
    "audit:run-autocannon": "node ./scripts/audit/run-autocannon.js",
    "audit:open-dashboard": "next dev src/app/admin/performance",
    "native:prepare": "node ./scripts/native-prepare.js",
    "drive:healthcheck": "node ./scripts/drive-healthcheck.js",
    "clean": "rimraf .next"
  },

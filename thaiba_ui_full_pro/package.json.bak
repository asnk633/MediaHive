{
  "name": "thaiba-ui-full-pro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:rules": "jest src/__tests__/firestore.rules.test.ts src/__tests__/firestore.integration.test.ts --runInBand",
    "seed:e2e": "node scripts/seed-e2e-user.js",
    "auth:gen": "cross-env BASE_URL=http://127.0.0.1:3001 E2E_TEST_EMAIL=smoke@test.local E2E_TEST_PW=Pass123 node scripts/generateStorageState.js",
    "test:e2e": "cross-env BASE_URL=http://127.0.0.1:3001 playwright test --project=chromium --workers=1 --retries=1",
    "debug:testenv": "node tools/run_test_env.js"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "firebase": "^10.7.0",
    "framer-motion": "^10.12.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.11.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.0",
    "cross-env": "^10.1.0",
    "firebase-admin": "^13.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.0",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
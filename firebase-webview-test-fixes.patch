+import { test as base } from '@playwright/test';
+
+// Mock Firebase configuration
+const MOCK_FIREBASE_CONFIG = {
+  apiKey: "AIzaSyMockFirebaseKey1234567890",
+  authDomain: "mock-project.firebaseapp.com",
+  projectId: "mock-project-id",
+  storageBucket: "mock-project.appspot.com",
+  messagingSenderId: "123456789012",
+  appId: "1:123456789012:web:abcdef1234567890abcdef"
+};
+
+export const test = base.extend<{
+  mockFirebase: (enable?: boolean) => Promise<void>;
+}>({
+  mockFirebase: async ({ page }, use) => {
+    const mockFirebaseFn = async (enable: boolean = true) => {
+      if (!enable) return;
+      
+      // Intercept fetch requests to /firebase-config.json
+      await page.route('**/firebase-config.json', route => {
+        route.fulfill({
+          status: 200,
+          contentType: 'application/json',
+          body: JSON.stringify(MOCK_FIREBASE_CONFIG),
+        });
+      });
+      
+      // Mock Firebase initialization
+      await page.addInitScript(() => {
+        // Only mock if not already mocked and USE_REAL_FIREBASE is not set
+        const useRealFirebase = window.localStorage.getItem('USE_REAL_FIREBASE') === 'true' || 
+                               (window as any).USE_REAL_FIREBASE === true;
+                               
+        if (useRealFirebase) {
+          console.log('[FIREBASE][MOCK] Skipping mock, using real Firebase');
+          return;
+        }
+        
+        // Set a flag to indicate we're using mock
+        (window as any).__FIREBASE_MOCK_ENABLED = true;
+        
+        // Mock Firebase global object
+        (window as any).firebase = {
+          apps: [{ name: '[DEFAULT]' }],
+          initializeApp: (config: any) => {
+            console.log('[FIREBASE][MOCK] initializeApp called with config:', config);
+            return { name: '[DEFAULT]' };
+          },
+          getApp: () => ({ name: '[DEFAULT]' }),
+          getApps: () => [{ name: '[DEFAULT]' }],
+          auth: () => ({
+            setPersistence: async (persistence: any) => {
+              console.log('[FIREBASE][MOCK] persistence set to:', persistence);
+              // Set a global flag to indicate Firebase is ready
+              (window as any).__FIREBASE_READY__ = true;
+              return Promise.resolve();
+            },
+            onAuthStateChanged: (callback: any) => {
+              console.log('[FIREBASE][MOCK] onAuthStateChanged registered');
+              // Call callback immediately with null user (not signed in)
+              setTimeout(() => callback(null), 0);
+              return () => {}; // unsubscribe function
+            }
+          }),
+          firestore: () => ({
+            collection: () => ({
+              doc: () => ({
+                get: () => Promise.resolve({ exists: false, data: () => ({}) }),
+                set: () => Promise.resolve(),
+                update: () => Promise.resolve()
+              })
+            })
+          })
+        };
+        
+        console.log('[FIREBASE][MOCK] Firebase mock installed');
+      });
+    };
+    
+    await use(mockFirebaseFn);
+  },
+});
+
+export { expect } from '@playwright/test';


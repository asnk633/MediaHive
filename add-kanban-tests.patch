+import type { Page } from '@playwright/test';
+
+const BASE = process.env.PLAYWRIGHT_BASE_URL || '';
+const TEST_EMAIL = process.env.PLAYWRIGHT_TEST_EMAIL || 'dev@local';
+
+async function login(page: Page) {
+  const resp = await page.request.get(`${BASE}/api/users`);
+  if (!resp.ok()) throw new Error('Failed to fetch users: ' + await resp.text());
+  const users = await resp.json();
+  const user = users.find((u: any) => u.email === TEST_EMAIL) || users[0];
+  if (!user) throw new Error('No users available for login');
+  await page.addInitScript((u) => localStorage.setItem('user', JSON.stringify(u)), user);
+  return user;
+}
+
+async function seedTask(page: Page, user: any, overrides = {}) {
+  const r = await page.request.post(`${BASE}/api/tasks`, {
+    data: {
+      institutionId: 1,
+      title: 'm2-review-task',
+      description: 'seeded review task',
+      status: 'todo',
+      priority: 'high',
+      ...overrides,
+    },
+    headers: { 'x-user-data': JSON.stringify(user) },
+  });
+  if (!r.ok()) throw new Error('Seed failed: ' + await r.text());
+  const json = await r.json();
+  return json.data;
+}
+
+test.describe('M2 - Task review flow', () => {
+  test.beforeEach(async ({ page }) => {
+    const me = await login(page);
+    await seedTask(page, me);
+  });
+
+  test('happy path: reviewer can set approved status', async ({ page }) => {
+    await page.goto('/tasks');
+    await page.waitForSelector('.task-row', { timeout: 15000 });
+    const card = page.locator('.task-row').first();
+    await expect(card).toBeVisible();
+    // set review via UI select if exists
+    const sel = card.locator('select');
+    if (await sel.count() === 0) {
+      test.skip(true, 'No review select control present in UI');
+      return;
+    }
+    await sel.selectOption('approved');
+    await card.locator('text=Save').click();
+    await expect(page.getByText('Review updated')).toBeVisible();
+  });
+
+  test('error path: invalid review value returns validation error', async ({ page }) => {
+    await page.goto('/tasks');
+    await page.waitForSelector('.task-row', { timeout: 15000 });
+    const card = page.locator('.task-row').first();
+    await expect(card).toBeVisible();
+    // attempt to set invalid value via API
+    const id = await card.getAttribute('data-task-id');
+    test.skip(!id, 'task id not present in DOM; add data-task-id to TaskItem for e2e');
+    // Post an invalid review value
+    const meResp = await page.request.get(`${BASE}/api/users`);
+    const me = (await meResp.json()).find((u: any) => u.email === (process.env.PLAYWRIGHT_TEST_EMAIL || 'dev@local')) || null;
+    if (!me) test.skip('no test user available');
+    const r = await page.request.patch(`${BASE}/api/tasks/${id}`, {
+      data: { reviewStatus: 'INVALID_VALUE' },
+      headers: { 'x-user-data': JSON.stringify(me) },
+    });
+    // expect 400 or 422
+    expect([400, 422].includes(r.status())).toBeTruthy();
+  });
+});

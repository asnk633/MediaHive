rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Role Resolution (Legacy Pattern: Document Lookup)
    // NOTE: This assumes 'users/{uid}' exists and has 'role' and 'institutionId'.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return getUserData().role;
    }

    // Institution Scoping Guard
    // CRITICAL: Ensures users only access data within their institution.
    function userInstitutionId() {
      return getUserData().institutionId;
    }

    // Role Helpers
    function isAdmin() {
      // Check Custom Claims first (Performance & Reliability)
      return request.auth.token.admin == true || userRole() == "admin";
    }

    function isTeam() {
      return request.auth.token.isTeam == true || userRole() == "team";
    }

    function isGuest() {
      return userRole() == "guest";
    }

    function isOwner(resource) {
      return resource.data.createdBy == request.auth.uid;
    }

    // --- SCOPED ACCESS GUARDS ---
    // Enforce that the resource belongs to the same institution as the user.
    function isScoped(resource) {
       return resource.data.institutionId == userInstitutionId();
    }
    
    // For Create requests, ensure the new document is tagged correctly.
    function isScopedCreate(requestData) {
       return requestData.institutionId == userInstitutionId();
    }

    // --- SPECIFIC RULES ---

    // 1. TASKS
    match /tasks/{taskId} {
      allow read: if isSignedIn() && isScoped(resource) && (isAdmin() || isTeam() || (isGuest() && isOwner(resource)));
      allow create: if isSignedIn() && isScopedCreate(request.resource.data) && (isAdmin() || isTeam() || (isGuest() && request.resource.data.status == 'pending'));
      allow update: if isSignedIn() && isScoped(resource) && (
        isAdmin() || 
        (isTeam() && resource.data.status != 'done') || 
        (isGuest() && isOwner(resource) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'remarks', 'updatedAt']))
      );
      allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }

    // 2. DEVICE REQUESTS
    match /device_requests/{requestId} {
      allow read: if isSignedIn() && isScoped(resource) && (isAdmin() || isTeam() || isOwner(resource));
      allow create: if isSignedIn() && isScopedCreate(request.resource.data); 
      allow update: if isSignedIn() && isScoped(resource) && isAdmin();
      allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }

    // 1. INVENTORY (Strict Asset Control)
    // RISK: If Admin UI uses client-side writes, they WILL be blocked if not scoped correctly.
    match /inventory/{itemId} {
      // Read: All roles (within Scope) OR Admin
      allow read: if isSignedIn() && (isScoped(resource) || isAdmin());
      
      // Create: Admin OR Team (Team allowed for flexibility, consider restricting to Admin if strict)
      allow create: if isSignedIn() && isScopedCreate(request.resource.data) && (isAdmin() || isTeam());
      
      // Update: Granular Control
      allow update: if isSignedIn() && isScoped(resource) && (
        isAdmin() || // Admin can change everything
        (
            isTeam() && // Team can ONLY change operational fields
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'condition', 'updatedAt', 'notes', 'locationStr'])
        )
      );
      
      // Delete: Admin Only (Destructive)
      allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }

    // 2. INVENTORY LOGS (Immutable Audit Trail)
    // INTENT: Append-only history of what happened.
    match /inventory_logs/{logId} {
        // Read: Staff Only (Guest should not see internal logs)
        allow read: if isSignedIn() && isScoped(resource) && (isAdmin() || isTeam());
        
        // Create: Append Only (Admin/Team)
        allow create: if isSignedIn() && isScopedCreate(request.resource.data) && (isAdmin() || isTeam());
        
        // Write (Update/Delete): ABSOLUTELY DENIED
        allow update, delete: if false; 
    }

    // 3. INVENTORY REQUESTS (Guest Interaction)
    match /inventory_requests/{id} {
      // Read: Users can see their own requests; Staff can see all scoped requests.
      allow read: if isSignedIn() && isScoped(resource) && (
        resource.data.userId == request.auth.uid || isAdmin() || isTeam()
      );

      // Create: Anyone (Guest/Staff) can create a request Pending
      allow create: if isSignedIn()
        && isScopedCreate(request.resource.data)
        && request.resource.data.status == "pending"
        // Ensure user is requesting for THEMSELVES
        && request.resource.data.userId == request.auth.uid;

      // Update: Staff Approval / User Cancellation
      allow update: if isSignedIn() && isScoped(resource) && (
        // Admin/Team: Approval/Rejection
        (
            (isAdmin() || isTeam()) &&
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'approvedBy', 'approvedAt', 'rejectionReason', 'issuedIssueId'])
        ) ||
        // User: Cancel (Only if pending)
        (
            resource.data.userId == request.auth.uid &&
            resource.data.status == "pending" &&
            request.resource.data.status == "cancelled"
        )
      );

      // Delete: Admin Only (Or soft-delete via status preferred)
      allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }

    // 4. INVENTORY ISSUES (Active Loans)
    match /inventory_issues/{id} {
      // Read: Staff (to manage) + The Borrower (to see their loan)
      allow read: if isSignedIn() && (
        isAdmin() || 
        (isScoped(resource) && (isTeam() || resource.data.issuedToUserId == request.auth.uid))
      );

      // Create: Staff Only (Issuing an item)
      allow create: if isSignedIn()
        && isScopedCreate(request.resource.data)
        && (isAdmin() || isTeam());

      // Update: Staff Only (Returns)
      allow update: if isSignedIn()
        && isScoped(resource)
        && (isAdmin() || isTeam())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['returnedAt', 'conditionIn', 'status', 'overdueNotified', 'reminded24h', 'escalationNotified']);

      // Delete: Admin Only
      allow delete: if isSignedIn() && isAdmin();
    }

    // 7. EVENTS (Strict Admin/Team Management)
    match /events/{eventId} {
        // Read: All Scoped Users
        allow read: if isSignedIn() && isScoped(resource);
        // Create: Admin, Team, Guest (Restricted to 'request' type)
        allow create: if isSignedIn() && isScopedCreate(request.resource.data) && (
            isAdmin() || 
            isTeam() || 
            (isGuest() && request.resource.data.type == 'request')
        );
        // Update: Admin or Team (Guests CANNOT update)
        // Team cannot change critical metadata (createdBy, institution, type)
        allow update: if isSignedIn() && isScoped(resource) && (
            isAdmin() || 
            (isTeam() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy', 'institutionId', 'type']))
        );
        // Delete: Admin Only
        allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }
    
    // 6. SYSTEM EVENTS (Audit Logs - Immutable)
    match /system-events/{eventId} {
      allow read: if isSignedIn() && isScoped(resource) && isAdmin();
      allow create: if isSignedIn() && isScopedCreate(request.resource.data) && isAdmin(); 
      allow delete: if false; 
    }

    // 5. NOTIFICATIONS (Private & System Managed)
    match /notifications/{notifId} {
        // Read: Target User OR Admin
        allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        
        // Create: Admin Only (Server-side/Cron often uses Admin SDK which bypasses this, but good for client simulators)
        allow create: if isSignedIn() && isAdmin();

        // Update: User can Mark Read/Archive
        allow update: if isSignedIn() && (
             // Owner can change read/archived status
             (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'isArchived'])) ||
             isAdmin()
        );
        
        // Delete: Admin Only
        allow delete: if isSignedIn() && isAdmin();
    }

    // 6. STRUCTURE (Admin Config)
    match /institutions/{instId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isAdmin();
    }
    match /departments/{deptId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isAdmin();
    }

    // 7. USERS (Admin Managed + Self Profile)
    match /users/{userId} {
      // READ: Users see themselves; Admins see all.
      // NOTE: Direct Firestore list access is intentionally RESTRICTED. 
      // All user listings must go through Admin APIs.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // UPDATE: Admin (Any) OR User (Self - Safe Fields Only)
      allow update: if isSignedIn() && (
        isAdmin() || 
        (
            request.auth.uid == userId && 
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatarUrl', 'name', 'updatedAt', 'photoURL'])
        )
      );
      
      // CREATE/DELETE: Admin Only (Strict Access Control)
      allow create, delete: if isSignedIn() && isAdmin();
    }

    // 10. FILES (Metadata only - Storage rules separate)
    match /files/{fileId} {
       allow read: if isSignedIn(); 
       allow write: if false; 
    }

    // 11. CHATS
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      // Allow participants to update (to change last message or add users)
      // Allow Admins/Managers to update (to remove users)
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participantIds || isAdmin() || isTeam());
      allow delete: if isSignedIn() && isAdmin();
    }

    // 12. MESSAGES
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      allow create: if isSignedIn() 
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false; // Messages are immutable
    }
  }
}
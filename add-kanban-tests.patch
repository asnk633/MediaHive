+// e2e/playwright/helpers/drag.ts
+import type { Page } from '@playwright/test';
+
+/** Simple drag helper that moves element by offsets */
+export default async function drag(page: Page, sourceSelector: string, deltaX: number, deltaY: number) {
+  const src = await page.locator(sourceSelector).first();
+  const box = await src.boundingBox();
+  if (!box) throw new Error('source boundingBox not found: ' + sourceSelector);
+  const startX = box.x + box.width / 2;
+  const startY = box.y + box.height / 2;
+  await page.mouse.move(startX, startY);
+  await page.mouse.down();
+  await page.mouse.move(startX + deltaX, startY + deltaY, { steps: 10 });
+  await page.mouse.up();
+}

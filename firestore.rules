rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Role Resolution
    // Note: This relies on the physical 'users' document existing.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return getUserData().role;
    }

    // Institution Scoping Guard
    function userInstitutionId() {
      return getUserData().institutionId;
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function isTeam() {
      return userRole() == "team";
    }

    function isGuest() {
      return userRole() == "guest";
    }

    function isOwner(resource) {
      return resource.data.createdBy == request.auth.uid;
    }

    // --- SCOPED ACCESS GUARDS ---
    // Enforce that the resource belongs to the same institution as the user.
    function isScoped(resource) {
       return resource.data.institutionId == userInstitutionId();
    }
    
    // For Create requests, ensure the new document is tagged correctly.
    function isScopedCreate(requestData) {
       return requestData.institutionId == userInstitutionId();
    }

    // --- SPECIFIC RULES ---

    // 1. TASKS
    match /tasks/{taskId} {
      allow read: if isSignedIn() && isScoped(resource) && (isAdmin() || isTeam() || (isGuest() && isOwner(resource)));
      allow create: if isSignedIn() && isScopedCreate(request.resource.data) && (isAdmin() || isTeam() || (isGuest() && request.resource.data.status == 'pending'));
      allow update: if isSignedIn() && isScoped(resource) && (
        isAdmin() || 
        (isTeam() && resource.data.status != 'done') || 
        (isGuest() && isOwner(resource) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'remarks', 'updatedAt']))
      );
      allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }

    // 2. DEVICE REQUESTS
    match /device_requests/{requestId} {
      allow read: if isSignedIn() && isScoped(resource) && (isAdmin() || isTeam() || isOwner(resource));
      allow create: if isSignedIn() && isScopedCreate(request.resource.data); 
      allow update: if isSignedIn() && isScoped(resource) && isAdmin();
      allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }

    // 3. INVENTORY (Strict Admin Ownership)
    match /inventory/{itemId} {
      allow read: if isSignedIn() && isScoped(resource);
      // Create: Admin Only
      allow create: if isSignedIn() && isScopedCreate(request.resource.data) && isAdmin();
      // Update: Admin (All) OR Team (Status/Condition Only)
      allow update: if isSignedIn() && isScoped(resource) && (
        isAdmin() || 
        (isTeam() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'condition', 'updatedAt']))
      );
      // Delete: Admin Only
      allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }

    // 4. INVENTORY LOGS (New - Immutable Audit Trail)
    match /inventory_logs/{logId} {
        // Read: Admin or Team
        allow read: if isSignedIn() && isScoped(resource) && (isAdmin() || isTeam());
        // Create: Admin or Team (Append Only)
        allow create: if isSignedIn() && isScopedCreate(request.resource.data) && (isAdmin() || isTeam());
        // Update/Delete: Deny (Immutable)
        allow write: if false; 
    }

    // 5. INVENTORY REQUESTS (Guest Requests)
    match /inventory_requests/{id} {
      allow read: if isSignedIn() && isScoped(resource);

      allow create: if isSignedIn()
        && isGuest()
        && isScopedCreate(request.resource.data)
        && request.resource.data.status == "pending";

      allow update: if isSignedIn()
        && isAdmin()
        && request.resource.data.diff(resource.data)
           .affectedKeys()
           .hasOnly(['status', 'approvedBy', 'approvedAt', 'rejectionReason']);

      allow delete: if false;
    }

    // 6. INVENTORY ISSUES (Issuance & Returns)
    match /inventory_issues/{id} {
      allow read: if isSignedIn() && isScoped(resource);

      allow create: if isSignedIn()
        && isScopedCreate(request.resource.data)
        && (isAdmin() || isTeam());

      allow update: if isSignedIn()
        && isScoped(resource)
        && (isAdmin() || isTeam())
        && request.resource.data.diff(resource.data)
           .affectedKeys()
           .hasOnly(['returnedAt', 'conditionIn', 'status']);

      allow delete: if isSignedIn() && isAdmin();
    }

    // 7. EVENTS (Strict Admin/Team Management)
    match /events/{eventId} {
        // Read: All Scoped Users
        allow read: if isSignedIn() && isScoped(resource);
        // Create: Admin, Team, Guest (Restricted to 'request' type)
        allow create: if isSignedIn() && isScopedCreate(request.resource.data) && (
            isAdmin() || 
            isTeam() || 
            (isGuest() && request.resource.data.type == 'request')
        );
        // Update: Admin or Team (Guests CANNOT update)
        // Team cannot change critical metadata (createdBy, institution, type)
        allow update: if isSignedIn() && isScoped(resource) && (
            isAdmin() || 
            (isTeam() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy', 'institutionId', 'type']))
        );
        // Delete: Admin Only
        allow delete: if isSignedIn() && isScoped(resource) && isAdmin();
    }
    
    // 6. SYSTEM EVENTS (Audit Logs - Immutable)
    match /system-events/{eventId} {
      allow read: if isSignedIn() && isScoped(resource) && isAdmin();
      allow create: if isSignedIn() && isScopedCreate(request.resource.data) && isAdmin(); 
      allow delete: if false; 
    }

    // 7. NOTIFICATIONS (Expanded Admin Access)
    match /notifications/{notifId} {
        // Read: Target User OR Admin
        allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        // Create/Update: Admin Only
        allow write: if isSignedIn() && isAdmin();
    }

    // 8. STRUCTURE (Institutions & Departments - Admin Config)
    match /institutions/{instId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isAdmin();
    }
    match /departments/{deptId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isAdmin();
    }

    // 9. USERS (Admin Managed)
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && isAdmin(); 
    }

    // 10. FILES (Metadata only - Storage rules separate)
    match /files/{fileId} {
       allow read: if isSignedIn(); 
       allow write: if false; 
    }
  }
}
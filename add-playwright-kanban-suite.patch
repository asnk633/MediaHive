+import { test as base, type Page } from '@playwright/test';
+
+/**
+ * Fixtures for Kanban e2e tests.
+ *
+ * - authUser: fetches the test user from the backend (PLAYWRIGHT_TEST_EMAIL)
+ *   and injects it into localStorage before the first navigation.
+ *
+ * Usage:
+ *   import { test, expect } from './fixtures';
+ *   test('example', async ({ page, authUser }) => { ... });
+ */
+
+type User = Record<string, any>;
+
+export const test = base.extend<{
+  authUser: User;
+}>({
+  authUser: [
+    // Auto fixture - provides the authenticated test user object
+    async ({ page, baseURL }, use) => {
+      const baseUrl = (process.env.PLAYWRIGHT_BASE_URL || baseURL || 'http://localhost:3000').replace(/\/$/, '');
+      const email = process.env.PLAYWRIGHT_TEST_EMAIL || 'dev@local';
+
+      // Fetch users from real API and find the test user
+      const resp = await page.request.get(`${baseUrl}/api/users`);
+      if (!resp.ok()) {
+        throw new Error(`Failed to fetch users for auth fixture: ${resp.status()} ${await resp.text()}`);
+      }
+      const users = await resp.json();
+      const user = Array.isArray(users) ? users.find((u: any) => u.email === email) : null;
+      if (!user) {
+        throw new Error(`auth fixture: user with email "${email}" not found. returned users: ${JSON.stringify(users).slice(0, 200)}`);
+      }
+
+      // Ensure user is injected before navigation/hydration:
+      // addInitScript runs before any page script on subsequent navigations on this page.
+      await page.addInitScript((u) => {
+        try {
+          // localStorage key used by app for client auth (app uses 'user')
+          window.localStorage.setItem('user', JSON.stringify(u));
+        } catch (err) {
+          // ignore (shouldn't happen)
+        }
+      }, user);
+
+      await use(user);
+    },
+    { scope: 'test' },
+  ],
+});
+
+export const expect = test.expect;
+
+export default test;

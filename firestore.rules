rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function isTeam() {
      return userRole() == "team";
    }

    function isGuest() {
      return userRole() == "guest";
    }

    function isOwner(resource) {
      return resource.data.createdBy == request.auth.uid;
    }

    function canGuestUpdate(resource) {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly(["title", "description"]);
    }

    function canTeamUpdate(resource) {
      return !(resource.data.status == "pending" &&
               request.resource.data.status == "todo");
    }

    match /tasks/{taskId} {

      allow read: if isSignedIn() &&
        (
          isAdmin() ||
          isTeam() ||
          (isGuest() && resource.data.createdBy == request.auth.uid)
        );

      allow create: if isSignedIn() &&
        (
          isAdmin() ||
          isTeam() ||
          (isGuest() &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.status == "pending" &&
            request.resource.data.priority == "low" &&
            !("assignee" in request.resource.data)
          )
        );

      allow update: if isSignedIn() &&
        (
          isAdmin() ||
          (isTeam() && canTeamUpdate(resource)) ||
          (isGuest() && isOwner(resource) && canGuestUpdate(resource))
        );

      allow delete: if isSignedIn() && isAdmin();
    }

    match /tasks/{taskId}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        (
          isAdmin() ||
          resource.data.authorId == request.auth.uid
        );
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        (
          isAdmin() ||
          isTeam() ||
          (isGuest() && request.resource.data.status == "pending")
        );
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /files/{fileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || isTeam());
      allow delete: if isSignedIn() && isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
  }
}
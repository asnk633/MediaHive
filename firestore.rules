rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /** Safe role fetcher with fallback */
    function userRole() {
      return request.auth != null &&
             get(/databases/$(database)/documents/roles/$(request.auth.uid)).exists()
             ? get(/databases/$(database)/documents/roles/$(request.auth.uid)).data['role']
             : 'team'; // Default to team if no role doc exists
    }

    function isAuth() {
      return request.auth != null;
    }

    /* ROLES */
    match /roles/{uid} {
      allow read: if isAuth();
      allow write: if isAuth(); // Temporarily allow all authenticated users to write
    }

    /* USERS */
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAuth(); // Allow any authenticated user to write for now
    }

    /* TASKS */
    match /tasks/{id} {
      allow read: if isAuth();
      allow create: if isAuth(); // Simplified for testing
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    /* EVENTS */
    match /events/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    /* NOTIFICATIONS */
    match /notifications/{id} {
      allow read: if isAuth();
      allow create: if isAuth(); // Allow anyone to create for testing
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    /* FILES */
    match /files/{fileId} {
      allow read: if isAuth();
      allow create: if isAuth(); // Allow anyone for testing
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Catch-all: allow authenticated users to read/write
    match /{document=**} {
      allow read, write: if isAuth();
    }
  }
}

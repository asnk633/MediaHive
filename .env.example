# .env.example
# Database (your existing DB already configured)
DATABASE_URL=your-database-url-here

# Supabase storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Push keys (optional)
EXPO_SERVER_KEY=your-expo-server-key-here
FCM_SERVER_KEY=your-fcm-server-key-here
APN_KEY_ID=your-apn-key-id-here
APN_TEAM_ID=your-apn-team-id-here
APN_PRIVATE_KEY=your-apn-private-key-here

# Feature flags
FEATURE_FINANCE=false
FEATURE_MEDIA_ANALYZER=true
FEATURE_FACE_RECOGNITION=true

# External API settings
ENABLE_EXTERNAL_APIS=false

# Media analyzer settings
OPENCV_ENABLED=false
MEDIA_UPLOAD_RETENTION_DAYS=30

# Face recognition settings
FACE_PYTHON_SERVICE=true
VIP_MATCH_THRESHOLD=0.65

# Security settings
APP_SECRET=your-secret-key-here
SESSION_MAX_AGE=604800
REFRESH_TOKEN_MAX_AGE=2592000
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX=100

# File upload settings
MAX_UPLOAD_SIZE=10485760

# Monitoring webhook (optional)
MONITORING_WEBHOOK=https://your-monitoring-service.com/webhook